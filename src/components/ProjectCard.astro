---
interface Props {
  title: string;
  description: string;
  tags: string[];
  status: 'current' | 'past';
  link?: string;
}

const { title, description, tags, status, link } = Astro.props;
---

<div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
  <div class="flex items-center gap-2">
    <span class={`h-2 w-2 rounded-full ${status === 'current' ? 'bg-emerald-500' : 'bg-slate-300'}`}></span>
    <span class="text-xs font-medium uppercase tracking-wide text-slate-500">
      {status === 'current' ? 'Active' : 'Completed'}
    </span>
  </div>
  <h3 class="mt-2 font-medium text-slate-900">
    {link ? <a href={link} target="_blank" rel="noopener noreferrer" class="hover:text-teal-700">{title}</a> : title}
  </h3>
  <p class="mt-2 text-sm text-slate-600">{description}</p>
  <div class="mt-3 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600">{tag}</span>
    ))}
  </div>
</div>
