---
interface Props {
  title: string;
  description: string;
  tags: string[];
  link?: string;
}

const { title, description, tags, link } = Astro.props;
---

<div class="rounded-lg border border-slate-200 bg-white p-5">
  <h3 class="font-medium text-slate-900">
    {link ? <a href={link} target="_blank" rel="noopener noreferrer" class="hover:text-teal-700">{title}</a> : title}
  </h3>
  <p class="mt-2 text-sm text-slate-600">{description}</p>
  <div class="mt-3 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600">{tag}</span>
    ))}
  </div>
</div>
