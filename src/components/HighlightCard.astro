---
interface Props {
  title: string;
  summary: string;
  year: number;
  link?: string;
}

const { title, summary, year, link } = Astro.props;
---

<div class="rounded-xl border border-teal-100 bg-gradient-to-br from-teal-50/60 to-white p-5">
  <p class="text-xs font-semibold uppercase tracking-wide text-teal-600">{year}</p>
  <h3 class="mt-1 font-serif text-base font-semibold text-slate-900">
    {link ? <a href={link} target="_blank" rel="noopener noreferrer" class="hover:text-teal-700">{title}</a> : title}
  </h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-600">{summary}</p>
  {link && (
    <a href={link} target="_blank" rel="noopener noreferrer" class="mt-3 inline-block text-sm font-medium text-teal-700 hover:underline">
      Read the paper &rarr;
    </a>
  )}
</div>
