---
interface Props {
  date: Date;
  title: string;
}

const { date, title } = Astro.props;
const formatted = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<li class="flex gap-4 border-b border-slate-100 py-3 last:border-none">
  <span class="w-28 shrink-0 text-sm text-slate-500">{formatted}</span>
  <span class="text-slate-800">{title}</span>
</li>
