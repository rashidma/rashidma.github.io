---
import { site } from '../config';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/publications', label: 'Publications' },
  { href: '/projects', label: 'Projects' },
  { href: '/news', label: 'News' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex max-w-3xl flex-wrap items-center justify-between gap-4 px-6 py-4">
    <a href="/" class="font-serif text-lg font-semibold tracking-tight text-slate-900">
      {site.name}
    </a>
    <nav class="flex items-center gap-6 text-sm">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'transition-colors hover:text-teal-700',
            currentPath === link.href ? 'font-medium text-teal-700' : 'text-slate-600',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href={site.cvPath}
        download
        class="rounded-full border border-teal-700 px-3 py-1 text-teal-700 transition-colors hover:bg-teal-700 hover:text-white"
      >
        CV
      </a>
    </nav>
  </div>
</header>
