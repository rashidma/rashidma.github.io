---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import NewsItem from '../components/NewsItem.astro';

const news = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="News">
  <h1 class="font-serif text-2xl font-semibold text-slate-900">News</h1>
  <ul class="mt-6">
    {news.map((item) => <NewsItem date={item.data.date} title={item.data.title} />)}
  </ul>
</Layout>
