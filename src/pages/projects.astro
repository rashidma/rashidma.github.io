---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = await getCollection('projects');
const current = projects.filter((p) => p.data.status === 'current');
const past = projects.filter((p) => p.data.status === 'past');
---

<Layout title="Projects">
  <h1 class="font-serif text-2xl font-semibold text-slate-900">Projects</h1>

  {current.length > 0 && (
    <section class="mt-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Current</h2>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        {current.map((p) => <ProjectCard {...p.data} />)}
      </div>
    </section>
  )}

  {past.length > 0 && (
    <section class="mt-10">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Past</h2>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        {past.map((p) => <ProjectCard {...p.data} />)}
      </div>
    </section>
  )}
</Layout>
