---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PublicationItem from '../components/PublicationItem.astro';

const publications = (await getCollection('publications')).sort((a, b) => b.data.year - a.data.year);

const byYear = publications.reduce((acc, pub) => {
  const year = pub.data.year;
  (acc[year] ??= []).push(pub);
  return acc;
}, {});

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---

<Layout title="Publications">
  <h1 class="font-serif text-2xl font-semibold text-slate-900">Publications</h1>

  {years.map((year) => (
    <section class="mt-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">{year}</h2>
      <ul class="mt-2">
        {byYear[year].map((pub) => <PublicationItem {...pub.data} />)}
      </ul>
    </section>
  ))}
</Layout>
